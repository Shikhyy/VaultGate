# VaultGate Oracle Service — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to source control.

# ── Solana ──────────────────────────────────────────────
SOLANA_RPC_URL=https://api.devnet.solana.com
ACCESS_REGISTRY_PROGRAM_ID=

# Oracle keypair (base58-encoded secret key — use a burner for dev)
ORACLE_KEYPAIR=

# ── Fireblocks ──────────────────────────────────────────
FIREBLOCKS_API_KEY=
FIREBLOCKS_API_SECRET_PATH=./fireblocks_secret.key
FIREBLOCKS_PUBLIC_KEY=
FIREBLOCKS_BASE_URL=https://sandbox-api.fireblocks.io

# ── Service ─────────────────────────────────────────────
PORT=3001
LOG_DIR=./logs

# ── Development ─────────────────────────────────────────
# Set to "true" to simulate on-chain writes (no real Solana transactions)
MOCK_MODE=true
