# .env.example — copy to .env, fill in real values, NEVER commit .env
# See docs/pda-schema.md for account derivation details

# ── Solana ──────────────────────────────────────────────────────────────────
SOLANA_RPC_URL=https://api.devnet.solana.com
# Use private RPC for demo day (Helius / QuickNode):
# SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY

VAULT_PROGRAM_ID=3FQsKPw1T2X2NP87cfaxjNZzkq3M3PJ6FVcddAogowyq
HOOK_PROGRAM_ID=ENVRa3vVkjp1RhhUoLpJQEcHhqtkouK1hcfWiS6FQ7hb
ACCESS_REGISTRY_PROGRAM_ID=7Az1QtqjdEqrX6T6gtKhGdiSFTZ6cJxhicbi2o5vGE2q

# Accepted mint addresses (Token Extensions / Token 2022 mints only)
USDC_MINT=
EURC_MINT=

# ── Oracle keypair ───────────────────────────────────────────────────────────
# Base58 private key — use a BURNER wallet for dev, hardware wallet for prod
# This key can ONLY write to whitelist PDAs — it cannot touch vault funds
ORACLE_KEYPAIR=

# ── Fireblocks ───────────────────────────────────────────────────────────────
FIREBLOCKS_API_KEY=
FIREBLOCKS_API_SECRET_PATH=./fireblocks_secret.key
FIREBLOCKS_PUBLIC_KEY=          # for ECDSA webhook signature verification
FIREBLOCKS_BASE_URL=https://api.fireblocks.io
# Sandbox: FIREBLOCKS_BASE_URL=https://sandbox-api.fireblocks.io

# ── Frontend (Next.js) ───────────────────────────────────────────────────────
NEXT_PUBLIC_CLUSTER=devnet
NEXT_PUBLIC_DEMO_MODE=false     # set true for Zurich demo day
NEXT_PUBLIC_VAULT_ADDRESS=      # derived from vault-core PDA after deploy
NEXT_PUBLIC_ACCESS_REGISTRY_PROGRAM_ID=7Az1QtqjdEqrX6T6gtKhGdiSFTZ6cJxhicbi2o5vGE2q
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com
